---
import Base from "@/layouts/Base.astro";
---
<Base title="ANAMNESIS · architecture">
  <h1 class="text-2xl text-ink-50 mb-6">Architecture</h1>

  <pre class="bg-ink-900 border border-ink-700 rounded p-4 text-sm text-ink-200 overflow-x-auto leading-snug">
{`
  CAPTURE         DISTILL         INDEX           RETRIEVE+COMPOSE          RECEIPT
  -------         -------         -----           -----------------          -------
  Anthropic   ->  Heuristic   ->  sqlite      ->  Conformal threshold   ->  Ed25519 DSSE
  OpenAI          Claude Haiku    fastembed       k-NN over embeddings      EU AI Act 15+50
  DeepSeek                        numpy mtx       compose system prompt
  Gemini                                          attach receipt to call
  Mistral
`}
  </pre>

  <h2 class="text-xl text-ink-50 mt-10 mb-4">Modules</h2>
  <table class="w-full text-sm">
    <thead>
      <tr class="text-ink-500 border-b border-ink-700">
        <th class="text-left py-2 pr-4">module</th>
        <th class="text-left py-2 pr-4">purpose</th>
      </tr>
    </thead>
    <tbody class="text-ink-200">
      <tr class="border-b border-ink-900">
        <td class="py-2 pr-4 text-ink-50">anamnesis.conformal</td>
        <td class="py-2 pr-4">split + mondrian + conditional calibrators</td>
      </tr>
      <tr class="border-b border-ink-900">
        <td class="py-2 pr-4 text-ink-50">anamnesis.receipts</td>
        <td class="py-2 pr-4">Ed25519 signer + verifier, DSSE envelope</td>
      </tr>
      <tr class="border-b border-ink-900">
        <td class="py-2 pr-4 text-ink-50">anamnesis.capture</td>
        <td class="py-2 pr-4">5-provider trace adapters</td>
      </tr>
      <tr class="border-b border-ink-900">
        <td class="py-2 pr-4 text-ink-50">anamnesis.distill</td>
        <td class="py-2 pr-4">heuristic + AnthropicHaiku LLM distillation</td>
      </tr>
      <tr class="border-b border-ink-900">
        <td class="py-2 pr-4 text-ink-50">anamnesis.storage</td>
        <td class="py-2 pr-4">sqlite + numpy/fastembed vector index</td>
      </tr>
      <tr class="border-b border-ink-900">
        <td class="py-2 pr-4 text-ink-50">anamnesis.retrieve / .compose</td>
        <td class="py-2 pr-4">conformal-bounded retrieval + prompt splicing</td>
      </tr>
      <tr>
        <td class="py-2 pr-4 text-ink-50">anamnesis_server</td>
        <td class="py-2 pr-4">FastAPI app + per-tenant registry</td>
      </tr>
    </tbody>
  </table>
</Base>
